# 아래 둘 중 하나만 설정하면 됩니다. 둘 다 없으면 키워드/템플릿 기반 간이 로직으로 자동 폴백됩니다.
# GEMINI_API_KEY가 있으면 Gemini를, 없고 ANTHROPIC_API_KEY만 있으면 Claude를 사용합니다.

# Google AI Studio에서 발급 (무료 등급 있음): https://aistudio.google.com/apikey
GEMINI_API_KEY=
# 선택 사항: 기본값은 gemini-2.5-flash
GEMINI_MODEL=

# Anthropic 콘솔에서 발급 (결제 크레딧 필요): https://console.anthropic.com
ANTHROPIC_API_KEY=
# 선택 사항: 기본값은 claude-sonnet-4-5
ANTHROPIC_MODEL=
